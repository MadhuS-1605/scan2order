// Scan2Order — Prisma schema
// Datasource: PostgreSQL. Generator: prisma-client-js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RestaurantType {
  RESTAURANT
  CAFE
  HOTEL
  CLOUD_KITCHEN
  BAR
  QSR // fast food / self-serve restaurant (order at counter, pay first, pick up)
  BAKERY
  PIZZERIA
  BURGER_JOINT
  OTHER
}

enum AdminRole {
  OWNER
  MANAGER
  CASHIER
  WAITER
  KITCHEN
  STAFF
}

// How an order was placed: self-ordered by a diner via QR, or taken by staff.
enum OrderChannel {
  CUSTOMER
  STAFF
}

// Diner presence at order time (anti-fake-order). VERIFIED = on-site (or not
// required / staff order); UNVERIFIED = location not shared, held for staff
// confirmation; REMOTE = shared location was outside the venue (order blocked,
// so this value is not normally persisted).
enum OrderPresence {
  VERIFIED
  UNVERIFIED
  REMOTE
}

// Whether an attendance punch was made by the staff member (self, geofenced) or
// recorded/corrected by a manager.
enum AttendanceSource {
  SELF
  MANAGER
}

/// Whether placed orders go straight to the kitchen or need a waiter to confirm.
enum OrderConfirmationMode {
  AUTO
  WAITER_CONFIRM
}

/// When the customer is expected to pay.
enum PaymentTiming {
  PAY_BEFORE // pay at the time of ordering (common in hotels / QSRs)
  PAY_AFTER // request the bill at the end (common in cafes / dine-in)
}

enum GstMode {
  NONE
  INCLUSIVE // prices already include GST
  EXCLUSIVE // GST added on top of the subtotal
}

enum OrderStatus {
  PLACED // created by the customer, awaiting routing
  CONFIRMED // confirmed (by waiter, or auto) -> visible to kitchen
  PREPARING // kitchen started cooking
  READY // ready to serve / pick up
  SERVED // delivered to the table
  COMPLETED // closed out (paid + done)
  CANCELLED // cancelled or rejected
}

enum PaymentStatus {
  UNPAID
  PENDING // online payment initiated, awaiting confirmation
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  COUNTER
  ROOM
}

enum TableKind {
  TABLE
  ROOM
  COUNTER // self-service venue's single ordering/pickup point (no physical tables)
}

/// How guests order at a venue.
enum ServiceModel {
  TABLE_SERVICE // per-table QR; dine-in service (restaurants, cafes, hotels)
  SELF_SERVICE // single venue QR; order, prepay, pick up by number (counter / QSR / takeaway)
}

enum PaymentProvider {
  RAZORPAY
  COUNTER
}

enum OtpPurpose {
  WHATSAPP_BILL
  LOGIN
  ADMIN_LOGIN // super-admin 2FA (keyed by email)
}

enum BillDeliveryMethod {
  DOWNLOAD
  WHATSAPP
  EMAIL
}

// How an order is fulfilled. DINE_IN is the default (QR at a table); PICKUP and
// DELIVERY support counter/cloud-kitchen ordering.
enum Fulfillment {
  DINE_IN
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  UNASSIGNED
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
}

// A delivery rider/executive — closes the "Delivery Executive" gap vs.
// competitors. Assigned to DELIVERY-fulfillment orders for tracking.
model DeliveryRider {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  orders Order[]

  @@index([restaurantId])
  @@map("delivery_riders")
}

enum PushRole {
  RESTAURANT // admin/kitchen device — alerts on new orders
  CUSTOMER // diner device — alerts on their order status
}

enum ServiceRequestType {
  CALL_WAITER
  WATER
  BILL
  CLEAN_TABLE
  OTHER
}

enum ServiceRequestStatus {
  OPEN
  RESOLVED
}

enum CouponType {
  PERCENT
  FLAT
}

enum ReservationType {
  RESERVATION
  WAITLIST
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

// ---------------------------------------------------------------------------
// Tenancy & admin
// ---------------------------------------------------------------------------

// A connected third-party integration (POS / PMS / accounting / SSO / webhook).
// Credentials/settings live in `config`; most are scaffolding ready for real
// API wiring, except outbound webhooks which fire live on order events.
model Integration {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  provider     String // e.g. "petpooja", "webhook", "google-sso"
  category     String // POS | PMS | ACCOUNTING | SSO | WEBHOOK
  enabled      Boolean    @default(false)
  config       Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, provider])
  @@index([restaurantId])
  @@map("integrations")
}

// A franchise / multi-outlet group. One owner can manage several restaurants
// under a single login and switch the active property.
model PropertyGroup {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  restaurants Restaurant[]
  members     AdminUser[]

  @@map("property_groups")
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum RestaurantStatus {
  ACTIVE
  SUSPENDED
}

enum PlanCouponType {
  PERCENT // value = % off (0-100)
  AMOUNT // value = ₹ off
}

// Operator-editable plan pricing (overrides the code defaults in src/lib/plans.ts).
// Keyed by PlanTier value. Absent row => use the code default. Capabilities and
// limits stay code-defined; only price / allowances / trial are tunable live.
model PlanSetting {
  tier              String   @id // "FREE" | "STARTER" | "PRO" | "ENTERPRISE"
  price             Int
  whatsappAllowance Int
  emailAllowance    Int
  trialDays         Int      @default(14)
  updatedAt         DateTime @updatedAt

  @@map("plan_settings")
}

// Platform-issued promo code applied at subscription checkout (distinct from a
// tenant's own diner-facing Coupon). Managed by super-admins.
model PlanCoupon {
  id             String         @id @default(cuid())
  code           String         @unique
  type           PlanCouponType @default(PERCENT)
  value          Decimal        @db.Decimal(10, 2)
  active         Boolean        @default(true)
  maxRedemptions Int? // null = unlimited
  redeemedCount  Int            @default(0)
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  @@map("plan_coupons")
}

enum AnnouncementLevel {
  INFO
  WARNING
}

// Sub-role for super-admins (platform operators). FULL = everything; BILLING =
// revenue + plan grants; SUPPORT = tenant management + impersonation, no billing.
enum PlatformRole {
  FULL
  BILLING
  SUPPORT
}

// Global platform kill switches, keyed by a known string (see src/lib/platform/
// flags.ts). Absent row = the code default (usually enabled).
model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

// Internal super-admin note on a tenant (support context). Not visible to the
// tenant. See the per-tenant drill-down.
model TenantNote {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  authorId     String?
  authorName   String?
  body         String
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@map("tenant_notes")
}

// Platform-wide notice shown as a banner in every tenant admin. Managed by
// super-admins (src/app/superadmin/announcements).
model Announcement {
  id            String            @id @default(cuid())
  title         String
  body          String?
  level         AnnouncementLevel @default(INFO)
  active        Boolean           @default(true)
  createdByName String?
  createdAt     DateTime          @default(now())

  @@index([active, createdAt])
  @@map("announcements")
}

model Restaurant {
  id                     String           @id @default(cuid())
  name                   String
  slug                   String           @unique
  groupId                String?
  group                  PropertyGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  planTier               PlanTier         @default(FREE)
  // Paid/trial period end for the current tier. null on FREE (free forever).
  // When a paid tier's window lapses, the venue falls back to FREE-tier limits.
  planActiveUntil        DateTime?
  planIsTrial            Boolean          @default(false)
  // Auto-renew (Razorpay subscription / eMandate). When active, subscription.charged
  // webhooks extend planActiveUntil each cycle.
  planAutoRenew          Boolean          @default(false)
  razorpaySubscriptionId String?
  // Payment id from the last subscription.charged/activated webhook we acted
  // on — Razorpay can redeliver the same event, so this makes extending
  // planActiveUntil idempotent per payment instead of per delivery.
  lastSubscriptionPaymentId String?
  // Platform lifecycle: a super-admin can SUSPEND a venue (blocks its admin until
  // reactivated). Default ACTIVE; diner-facing behaviour is unaffected for now.
  status                 RestaurantStatus @default(ACTIVE)
  suspendedAt            DateTime?
  suspendedReason        String?
  // Last time a dunning (trial-ending / lapsed) reminder was sent — cooldown so
  // the dunning cron doesn't re-notify daily. See src/lib/billing/dunning.ts.
  lastDunningAt          DateTime?
  type                   RestaurantType   @default(RESTAURANT)
  email                  String?
  phone                  String?
  addressLine            String?
  city                   String?
  state                  String?
  country                String           @default("India")
  postalCode             String?
  // FSSAI food-licence number, printed on the bill (Indian compliance).
  fssaiNumber            String?
  logoUrl                String?
  // Hex accent color (e.g. "#2a6f4b") applied to the diner-facing menu/bill —
  // "Powered by Scan2Order" branding stays, but the accent color is the
  // venue's own. Null falls back to Scan2Order's default brand color.
  brandColor             String?
  // Restaurant-chosen username used as the public subdomain (e.g. "spicegarden"
  // -> spicegarden.scan.to). Unique across the platform.
  subdomain              String?          @unique
  // monotonic per-restaurant order counter (incremented in a transaction)
  orderSeq               Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  config            OnboardingConfig?
  admins            AdminUser[]
  categories        MenuCategory[]
  menuItems         MenuItem[]
  ingredients       Ingredient[]
  ingredientLedger  IngredientLedgerEntry[]
  expenses          Expense[]
  suppliers         Supplier[]
  purchaseOrders    PurchaseOrder[]
  cashShifts        CashShift[]
  registers         Register[]
  deliveryRiders    DeliveryRider[]
  tables            RestaurantTable[]
  tableAreas        TableArea[]
  orders            Order[]
  refunds           Refund[]
  planPayments      PlanPayment[]
  pushSubscriptions PushSubscription[]
  serviceRequests   ServiceRequest[]
  coupons           Coupon[]
  feedback          Feedback[]
  reservations      Reservation[]
  banquetBookings   BanquetBooking[]
  integrations      Integration[]
  auditLogs         AuditLog[]
  attendance        StaffAttendance[]
  usageMeters       UsageMeter[]
  overageCharges    OverageCharge[]
  tenantNotes       TenantNote[]
  campaigns         Campaign[]

  @@index([groupId])
  @@map("restaurants")
}

// A marketing message blast a venue sends to its past guests (WhatsApp only —
// guest email isn't stored). Counts against the venue's WhatsApp allowance.
model Campaign {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  segment        String // "all" | "repeat" | "recent"
  message        String
  recipientCount Int        @default(0)
  sentCount      Int        @default(0)
  createdByName  String?
  createdAt      DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@map("campaigns")
}

// Metered usage for billable channels (WhatsApp / email). One row per
// (restaurant, month, channel); `count` is incremented on each successful send.
// Plans include a monthly allowance (see plan allowances in src/lib/plans.ts);
// usage beyond it accrues overage. Bucketed by calendar month ("YYYY-MM", UTC).
enum UsageChannel {
  WHATSAPP
  EMAIL
}

model UsageMeter {
  id                String       @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  period            String // calendar month bucket, "YYYY-MM"
  channel           UsageChannel
  count             Int          @default(0)
  // Highest allowance threshold (e.g. 80, 100) the owner has been notified at
  // this period — prevents repeat alerts. Resets with each month's new row.
  notifiedThreshold Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([restaurantId, period, channel])
  @@index([restaurantId, period])
  @@map("usage_meters")
}

// A settlement of one closed month's metered overage (WhatsApp + email beyond
// the plan allowance). Snapshots the billed units + ₹ amount at settle time. A
// PAID row marks that month as settled so it's never billed twice; non-PAID
// rows are transient (rebuilt on each settle attempt). Collected either
// standalone ("Settle overage") or bundled into a plan-extend order — see
// src/lib/billing/overage.ts.
model OverageCharge {
  id                String        @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  period            String // calendar month settled, "YYYY-MM"
  whatsappUnits     Int           @default(0)
  emailUnits        Int           @default(0)
  amount            Decimal       @db.Decimal(10, 2) // pre-GST ₹, snapshotted at settle
  status            PaymentStatus @default(PENDING)
  razorpayOrderId   String? // shared by all charges settled in one payment
  razorpayPaymentId String?       @unique // captured-payment id is single-use across the platform
  planPaymentId     String? // set when bundled into a plan-extend order
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([restaurantId, period])
  @@index([restaurantId])
  @@index([razorpayOrderId])
  @@map("overage_charges")
}

model AdminUser {
  id                String            @id @default(cuid())
  // Owners sign in with email (globally unique). Staff are assigned a username
  // by their restaurant and need no email — username is unique *within* a
  // restaurant (see @@unique below). Email is nullable so staff can omit it.
  email             String?           @unique
  username          String?
  passwordHash      String
  // Google OAuth subject id, set when an owner links/signs in with Google.
  googleId          String?           @unique
  name              String
  role              AdminRole         @default(OWNER)
  isSuperAdmin      Boolean           @default(false)
  // Sub-role when isSuperAdmin — gates which platform actions are allowed.
  platformRole      PlatformRole      @default(FULL)
  // Authenticator-app (TOTP) 2FA. Base32 secret; enabled only after the user
  // confirms a code during enrolment. Email OTP works as an alternative factor.
  totpSecret        String? // AES-GCM encrypted when ENCRYPTION_KEY is set (else plaintext)
  totpEnabled       Boolean           @default(false)
  // Highest TOTP time-step already consumed — prevents replay within the window.
  lastTotpStep      Int?
  // One-time set-password invite (operator-created owners). Token cleared on use.
  inviteToken       String?           @unique
  inviteTokenExpiry DateTime?
  // Disabled accounts keep their history/audit attribution but cannot sign in.
  disabled          Boolean           @default(false)
  restaurantId      String?
  restaurant        Restaurant?       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  groupId           String?
  group             PropertyGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  ordersCreated     Order[]           @relation("OrderCreatedBy")
  attendance        StaffAttendance[]
  cashShifts        CashShift[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([restaurantId, username])
  @@index([restaurantId])
  @@index([groupId])
  @@map("admin_users")
}

/// One row per restaurant — drives runtime behavior (routing, payments, tax).
model OnboardingConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  serviceModel      ServiceModel @default(TABLE_SERVICE)
  // Pay-first: hold the order out of the kitchen until it is paid (then it
  // auto-confirms). Default on for self-service venues.
  requirePrepayment Boolean      @default(false)

  // Venue local timezone (IANA, e.g. "Asia/Kolkata"). All time-of-day logic
  // (business hours, item availability windows, happy hour) is evaluated here,
  // NOT in the server's timezone.
  timezone              String                @default("Asia/Kolkata")
  // Daily ordering window in venue-local "HH:MM". null/null = open 24h. May span
  // midnight (e.g. 18:00 -> 02:00).
  openTime              String?
  closeTime             String?
  // Manual kill-switch: stop accepting new diner orders right now (e.g. kitchen
  // swamped, closing early), independent of business hours.
  orderingPaused        Boolean               @default(false)
  // Custom thank-you / footer line printed on the bill (falls back to a built-in
  // friendly quote when blank).
  billFooterMessage     String?
  // Default kitchen prep estimate (minutes) shown to the diner as "ready in ~N".
  defaultPrepMinutes    Int                   @default(15)
  // Email the owner an end-of-day sales summary (sent by the daily-summary cron).
  dailyReportEmail      Boolean               @default(false)
  // Minimum order subtotal (venue currency, whole units). 0 = no minimum.
  minOrderAmount        Int                   @default(0)
  // Takeaway / delivery ordering (e.g. cloud kitchens). When on, the diner picks
  // a fulfilment type at checkout; delivery also captures an address.
  pickupEnabled         Boolean               @default(false)
  deliveryEnabled       Boolean               @default(false)
  orderConfirmation     OrderConfirmationMode @default(AUTO)
  paymentTiming         PaymentTiming         @default(PAY_AFTER)
  onlinePaymentEnabled  Boolean               @default(false)
  counterPaymentEnabled Boolean               @default(true)

  gstMode              GstMode @default(NONE)
  gstNumber            String?
  // Registered legal name fetched from the GSTN (via the verification provider)
  // when the GSTIN is verified — used on tax invoices. Distinct from the
  // restaurant's display name. Null until a successful verification.
  gstLegalName         String?
  gstVerified          Boolean @default(false)
  gstPercentage        Decimal @default(5) @db.Decimal(5, 2)
  // Optional service charge added to the bill (percent of subtotal). 0 = none.
  serviceChargePercent Decimal @default(0) @db.Decimal(5, 2)
  currency             String  @default("INR")

  // Optional per-restaurant Razorpay account (falls back to platform env if null)
  razorpayKeyId     String?
  razorpayKeySecret String?

  // UPI VPA + payee name for the "scan to pay" QR on bills (e.g. cafe@oksbi).
  upiId   String?
  upiName String?

  // Guest Wi-Fi shown on the diner menu page. Both null = no Wi-Fi card shown.
  wifiSsid     String?
  wifiPassword String?

  // Which optional modules this venue uses — chosen at onboarding, drive which
  // admin sections show. Defaults are seeded from the venue type.
  featureReservations Boolean @default(true)
  featureRooms        Boolean @default(false) // hotel in-room dining
  featureBanquets     Boolean @default(false) // events / function halls
  featureBar          Boolean @default(false) // separate bar counter / KDS
  featureAttendance   Boolean @default(false) // staff clock-in/out tracking

  // Reservation slot capacity: reservedFor is bucketed into
  // reservationSlotMinutes-wide slots (e.g. 19:00-19:29), and the sum of
  // partySize already booked in a slot can't exceed reservationCapacityPerSlot.
  // Null = uncapped (default; opt-in per venue).
  reservationSlotMinutes     Int  @default(30)
  reservationCapacityPerSlot Int?

  // Venue location for attendance geofencing. When set, self clock-in/out is
  // only allowed within geofenceRadiusM metres of these coordinates.
  latitude        Float?
  longitude       Float?
  geofenceRadiusM Int    @default(150)

  // Anti-fake-order: require diners to be at the venue to place an order.
  // orderRadiusM is a more lenient radius than the staff geofence above.
  requireDinerLocation Boolean @default(false)
  orderRadiusM         Int     @default(300)

  // WhatsApp / messaging sender id (falls back to platform env if null)
  whatsappFrom String?

  // Link diners are nudged to for a public review (e.g. Google Maps).
  reviewUrl String?

  // Optional custom domain (e.g. order.spicegarden.com) the restaurant owns.
  customDomain String? @unique

  // Network thermal printer for kitchen tickets (ESC/POS over TCP, usually :9100).
  kotPrinterHost String?
  kotPrinterPort Int     @default(9100)

  // Supported menu languages, comma-separated codes (base is always English).
  languages String @default("en")

  // Happy hour — an automatic % discount on all items during a daily window.
  happyHourEnabled Boolean @default(false)
  happyHourFrom    String? // "HH:mm"
  happyHourTo      String?
  happyHourPercent Decimal @default(0) @db.Decimal(5, 2)

  onboardingStep      Int     @default(0)
  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_configs")
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  icon         String? // emoji shown in the customer menu's category rail
  // Station that prepares this category: "KITCHEN" (default) or "BAR".
  station      String     @default("KITCHEN")
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items MenuItem[]

  @@index([restaurantId])
  @@map("menu_categories")
}

model MenuItem {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  imageUrl     String?
  isVeg        Boolean @default(true)
  // Dietary attributes for diner filters / badges.
  isVegan      Boolean @default(false)
  isJain       Boolean @default(false)
  isSpicy      Boolean @default(false)
  isGlutenFree Boolean @default(false)
  isAvailable  Boolean @default(true) // in-stock toggle

  // Optional daily availability window ("HH:mm", 24h). Null => always available.
  availableFrom String?
  availableTo   String?

  isSpecialOfDay Boolean @default(false)
  isChefSpecial  Boolean @default(false) // chef's signature pick
  // A combo/meal bundle: sold as one orderable item at its own `price` (set
  // like any other item — typically a discount vs. buying the parts
  // separately), with comboLines listing what it includes for display/KOT
  // clarity. Deliberately NOT a "choose 1 of N" builder (e.g. "pick a side")
  // — each combo is a fixed set of items; add per-line choice groups later
  // if a fixed bundle turns out not to be enough.
  isCombo        Boolean @default(false)
  sortOrder      Int     @default(0)

  // Per-language overrides: { "hi": { "name": "...", "description": "..." } }
  translations Json?

  // Inventory. When trackStock is on, the item auto-hides at 0 and decrements
  // on each order; lowStockThreshold drives low-stock alerts.
  trackStock        Boolean @default(false)
  stockQty          Int     @default(0)
  lowStockThreshold Int     @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems     OrderItem[]
  modifierGroups ModifierGroup[]
  recipeLines    RecipeLine[]
  comboLines     ComboLine[]      @relation("ComboParent")
  includedInLines ComboLine[]     @relation("ComboIncludedItem")

  @@index([restaurantId])
  @@index([categoryId])
  @@map("menu_items")
}

// Raw material tracked for recipe-based costing (distinct from MenuItem's own
// trackStock, which gates a dish's own availability). Ingredient stock is
// decremented on order placement per RecipeLine, but never blocks a sale — it's
// for cost/wastage visibility, not an oversell guard.
model Ingredient {
  id                String   @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name              String
  unit              String // free text, e.g. "g", "ml", "pcs"
  stockQty          Decimal  @default(0) @db.Decimal(10, 2)
  lowStockThreshold Decimal  @default(0) @db.Decimal(10, 2)
  costPerUnit       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  recipeLines RecipeLine[]
  ledger      IngredientLedgerEntry[]
  poLines     PurchaseOrderLine[]

  @@unique([restaurantId, name])
  @@map("ingredients")
}

enum IngredientLedgerReason {
  ORDER_CONSUMPTION // deducted automatically for a placed/edited order
  WASTAGE // manually logged spillage/spoilage
  RESTOCK // manual restock or a received purchase order
  TRANSFER_OUT // moved to a sibling outlet in the same property group
  TRANSFER_IN // received from a sibling outlet
}

// Movement log for ingredient stock — the basis for the usage/wastage/cost
// report (/admin/inventory/reports). Ingredient.stockQty is the current
// balance; this is the ledger of how it got there.
model IngredientLedgerEntry {
  id           String                 @id @default(cuid())
  restaurantId String
  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient             @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  delta        Decimal                @db.Decimal(10, 3) // negative = consumed/wasted, positive = restocked
  reason       IngredientLedgerReason
  note         String?
  createdByName String?
  // Snapshot of Ingredient.costPerUnit at write time, so the usage/wastage
  // cost report reflects what the ingredient cost when actually consumed —
  // not whatever costPerUnit happens to be today (which is editable anytime).
  // Null on entries written before this field existed; the report falls back
  // to the ingredient's current cost for those, same as it always did.
  costPerUnit  Decimal?               @db.Decimal(10, 2)
  createdAt    DateTime               @default(now())

  @@index([restaurantId, createdAt])
  @@index([ingredientId])
  @@map("ingredient_ledger_entries")
}

// How much of an ingredient one serving of a menu item consumes.
model RecipeLine {
  id            String     @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId  String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qtyPerServing Decimal    @db.Decimal(10, 3)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@map("recipe_lines")
}

// A set of choices attached to a menu item. A "variant" (e.g. Size: Half/Full)
// is just a required single-select group (minSelect=1, maxSelect=1); add-ons are
// optional multi-select groups.
model ModifierGroup {
  id           String   @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name         String
  required     Boolean  @default(false)
  minSelect    Int      @default(0)
  maxSelect    Int      @default(1)
  sortOrder    Int      @default(0)
  // Per-language name overrides: { hi: { name }, kn: { name } } — mirrors MenuItem.
  translations Json?

  options ModifierOption[]

  @@index([menuItemId])
  @@map("modifier_groups")
}

model ModifierOption {
  id           String        @id @default(cuid())
  groupId      String
  group        ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name         String
  priceDelta   Decimal       @default(0) @db.Decimal(10, 2)
  sortOrder    Int           @default(0)
  isAvailable  Boolean       @default(true)
  // Per-language name overrides: { hi: { name }, kn: { name } }.
  translations Json?

  @@index([groupId])
  @@map("modifier_options")
}

// One item included in a combo MenuItem (MenuItem.isCombo). Display/KOT-only
// — the combo's own price is what's actually charged; this just lists what's
// in it (e.g. a "Burger Combo" listing 1x Burger, 1x Fries, 1x Coke).
model ComboLine {
  id            String   @id @default(cuid())
  comboId       String
  combo         MenuItem @relation("ComboParent", fields: [comboId], references: [id], onDelete: Cascade)
  includedItemId String
  includedItem  MenuItem @relation("ComboIncludedItem", fields: [includedItemId], references: [id], onDelete: Cascade)
  quantity      Int      @default(1)
  sortOrder     Int      @default(0)

  @@index([comboId])
  @@index([includedItemId])
  @@map("combo_lines")
}

// ---------------------------------------------------------------------------
// Tables & QR
// ---------------------------------------------------------------------------

model RestaurantTable {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String // e.g. "T1", "Patio 3", "204"
  kind         TableKind  @default(TABLE) // ROOM = hotel in-room dining point
  seats        Int        @default(4)
  qrToken      String     @unique // CSPRNG token encoded in the QR — set explicitly via newQrToken() (src/lib/qr.ts), never DB-defaulted
  isActive     Boolean    @default(true)
  areaId       String?
  area         TableArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  // Position on the visual floor-plan canvas, as a 0-100 percentage of the
  // canvas width/height. Null = not yet placed (falls back to the grid view).
  posX         Float?
  posY         Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orders          Order[]
  serviceRequests ServiceRequest[]

  @@index([restaurantId])
  @@index([areaId])
  @@map("restaurant_tables")
}

// A zone/section grouping tables — e.g. "Patio", "Indoor", "Rooftop" — for
// organizing the tables list. Purely organizational; doesn't affect ordering.
model TableArea {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  tables RestaurantTable[]

  @@index([restaurantId])
  @@map("table_areas")
}

// ---------------------------------------------------------------------------
// Customers (created at WhatsApp/bill stage; keyed by phone for dining history)
// ---------------------------------------------------------------------------

model Customer {
  id                  String    @id @default(cuid())
  phone               String    @unique
  name                String?
  loyaltyPoints       Int       @default(0)
  // When the diner's 24h WhatsApp customer-service window closes (set from the
  // inbound webhook whenever they message the business). While open, bills can
  // be delivered as free-form session messages for free — see
  // src/lib/billing/actions.ts (verifyBillOtpAction).
  whatsappWindowUntil DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders   Order[]
  feedback Feedback[]

  @@map("customers")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerId   String?
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderNumber Int // per-restaurant sequence (see Restaurant.orderSeq)
  status      OrderStatus @default(PLACED)

  // Groups all orders placed in one dining visit (same table, before the bill is
  // settled). Rounds accumulate into a single consolidated bill. Tip/coupon are
  // carried on the earliest ("primary") order of the session.
  diningSessionId String?

  // Optional diner details captured at order time (name for call-outs, phone
  // snapshot). A linked Customer (by phone) is created at the WhatsApp-bill step.
  customerName  String?
  customerPhone String?

  // Fulfilment. DINE_IN by default; DELIVERY carries the address.
  fulfillment     Fulfillment @default(DINE_IN)
  deliveryAddress String?
  // Rider assignment/tracking for DELIVERY orders — null for DINE_IN/PICKUP.
  deliveryRiderId String?
  deliveryRider   DeliveryRider?  @relation(fields: [deliveryRiderId], references: [id], onDelete: SetNull)
  deliveryStatus  DeliveryStatus?

  paymentStatus PaymentStatus  @default(UNPAID)
  paymentMethod PaymentMethod?

  // Money snapshots (so historical bills don't change if config/prices change)
  subtotal       Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @default(0) @db.Decimal(10, 2)
  tipAmount      Decimal @default(0) @db.Decimal(10, 2)
  // Coupon discount applied at the bill. Payable = total - discount + tip.
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  couponCode     String?
  // Amount paid so far (supports split / partial payments).
  amountPaid     Decimal @default(0) @db.Decimal(10, 2)
  // Loyalty points already credited for this order (guards double-award).
  pointsAwarded  Boolean @default(false)
  gstMode        GstMode @default(NONE)

  // Who placed the order, and through which channel. CUSTOMER = self-ordered via
  // QR; STAFF = taken by a waiter/cashier at the POS. createdByName is a snapshot
  // so attribution survives if the staff account is later deleted.
  channel       OrderChannel @default(CUSTOMER)
  createdById   String?
  createdBy     AdminUser?   @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName String?

  // Anti-fake-order: was the diner verified on-site when ordering? distanceM is
  // a rounded metres-from-venue (null when no location was shared). No exact
  // coordinates are stored.
  presence  OrderPresence @default(VERIFIED)
  distanceM Int?

  notes String?

  placedAt    DateTime  @default(now())
  confirmedAt DateTime?
  readyAt     DateTime?
  servedAt    DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items             OrderItem[]
  payments          Payment[]
  refunds           Refund[]
  bill              Bill?
  feedback          Feedback?
  pushSubscriptions PushSubscription[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status])
  @@index([tableId])
  @@index([customerId])
  @@index([diningSessionId])
  @@index([restaurantId, createdById])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String?
  menuItem      MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnapshot  String
  priceSnapshot Decimal   @db.Decimal(10, 2)
  quantity      Int       @default(1)
  notes         String?
  lineTotal     Decimal   @db.Decimal(10, 2)
  // Snapshot of chosen modifiers: [{ group, name, priceDelta }]
  modifiers     Json?
  // Manual override for "split the bill by person" — defaults to the parent
  // order's customerName when null (see peopleBreakdown in payment/page.tsx).
  splitLabel    String?
  // Per-item "prepared" ack, used by the bar KDS to tick off drinks
  // independently of the overall order status.
  preparedAt    DateTime?

  @@index([orderId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Payments & billing
// ---------------------------------------------------------------------------

// A tenant's payment toward their own subscription (distinct from diner order
// payments). Pay-to-extend: a successful payment adds `periodDays` to the plan.
model PlanPayment {
  id                String        @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tier              PlanTier
  amount            Decimal       @db.Decimal(10, 2)
  periodDays        Int           @default(30)
  status            PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?       @unique // captured-payment id is single-use across the platform
  // Promo code applied at checkout (PlanCoupon.code), if any.
  couponCode        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([restaurantId])
  @@index([razorpayOrderId])
  @@map("plan_payments")
}

enum RefundStatus {
  DONE // money returned (gateway refund created, or manual cash/counter refund)
  FAILED // gateway refused — staff must retry / handle manually
  PENDING // requested by staff without refund authority — awaiting manager approval, no money moved yet
  REJECTED // a manager declined the request — no money moved
}

// A refund issued against a paid order. Online refunds carry the gateway refund
// id; counter/cash refunds are recorded as a manual note (no gateway call).
model Refund {
  id              String        @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  reason          String?
  method          PaymentMethod
  gatewayRefundId String? // Razorpay refund id, when refunded online
  status          RefundStatus  @default(DONE)
  createdByName   String? // who requested/executed it
  approvedByName  String? // who approved/rejected a PENDING request
  createdAt       DateTime      @default(now())

  @@index([orderId])
  @@index([restaurantId])
  @@map("refunds")
}

model Payment {
  id       String          @id @default(cuid())
  orderId  String
  order    Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount   Decimal         @db.Decimal(10, 2)
  method   PaymentMethod
  provider PaymentProvider
  status   PaymentStatus   @default(PENDING)

  razorpayOrderId   String?
  razorpayPaymentId String? @unique // captured-payment id is single-use across the platform
  razorpaySignature String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("payments")
}

model Bill {
  id         String @id @default(cuid())
  orderId    String @unique
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  billNumber String @unique

  subtotal  Decimal @db.Decimal(10, 2)
  taxAmount Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
  gstMode   GstMode
  gstNumber String?

  deliveryMethod BillDeliveryMethod?
  sentToPhone    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bills")
}

model OtpVerification {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(WHATSAPP_BILL)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([phone, purpose])
  @@map("otp_verifications")
}

// Audit trail of sensitive admin actions (who changed what).
model AuditLog {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actorId      String?
  actorName    String?
  action       String // e.g. "staff.created", "settings.updated"
  detail       String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@map("audit_logs")
}

// Platform-operator (super-admin) action trail. Distinct from AuditLog, which is
// tenant-scoped: the actor here is a super-admin and the action may target a
// specific tenant (targetRestaurantId) or be platform-wide.
model PlatformAuditLog {
  id                 String   @id @default(cuid())
  actorId            String?
  actorName          String?
  action             String // e.g. "tenant.suspended", "tenant.impersonated", "plan.granted"
  targetRestaurantId String?
  detail             String?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([targetRestaurantId])
  @@map("platform_audit_logs")
}

// Staff clock-in / clock-out records. Self punches are geofenced (coords stored
// as proof); managers can mark or correct times (source = MANAGER).
model StaffAttendance {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  adminUserId  String
  adminUser    AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  clockInAt   DateTime
  clockOutAt  DateTime?
  clockInLat  Float?
  clockInLng  Float?
  clockOutLat Float?
  clockOutLng Float?

  source       AttendanceSource @default(SELF)
  markedById   String? // the manager who marked/corrected this, when source = MANAGER
  markedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, clockInAt])
  @@index([adminUserId, clockInAt])
  @@map("staff_attendance")
}

// Web Push subscriptions. Restaurant-scoped (admin/kitchen) or order-scoped
// (a diner's device for their own order).
model PushSubscription {
  id       String   @id @default(cuid())
  endpoint String   @unique
  p256dh   String
  auth     String
  role     PushRole

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId      String?
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([orderId])
  @@map("push_subscriptions")
}

// Diner-initiated service requests (call waiter, water, bill, clean table).
model ServiceRequest {
  id           String               @id @default(cuid())
  restaurantId String
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        RestaurantTable?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  type         ServiceRequestType
  note         String?
  status       ServiceRequestStatus @default(OPEN)
  createdAt    DateTime             @default(now())
  resolvedAt   DateTime?

  @@index([restaurantId, status])
  @@map("service_requests")
}

// Discount codes applied at the bill.
model Coupon {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  code         String
  type         CouponType
  value        Decimal    @db.Decimal(10, 2) // percent (0-100) or flat amount
  minOrder     Decimal    @default(0) @db.Decimal(10, 2)
  maxDiscount  Decimal?   @db.Decimal(10, 2) // cap for percentage coupons
  active       Boolean    @default(true)
  usageLimit   Int? // total redemptions allowed (null = unlimited)
  usedCount    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@map("coupons")
}

// Table bookings + walk-in waitlist.
model Reservation {
  id            String            @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type          ReservationType   @default(RESERVATION)
  customerName  String
  customerPhone String
  partySize     Int               @default(2)
  reservedFor   DateTime? // null for walk-in waitlist
  notes         String?
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime          @default(now())

  @@index([restaurantId, status])
  @@map("reservations")
}

enum BanquetStatus {
  ENQUIRY
  CONFIRMED
  COMPLETED
  CANCELLED
}

// A banquet / event booking (function hall, party, corporate event) with a
// pre-agreed menu and an optional advance deposit.
model BanquetBooking {
  id               String        @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customerName     String
  customerPhone    String
  eventType        String // Wedding, Birthday, Corporate, etc.
  eventDate        DateTime
  guestCount       Int           @default(20)
  hall             String? // hall / space name
  status           BanquetStatus @default(ENQUIRY)
  advanceAmount    Decimal       @default(0) @db.Decimal(10, 2)
  notes            String?
  // Set once the booking's pre-order has been fired to the kitchen as a real
  // Order — links to it and prevents converting twice.
  convertedOrderId String?
  items            BanquetItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([restaurantId, eventDate])
  @@map("banquet_bookings")
}

// A pre-ordered menu line for a banquet booking (price snapshot at add time).
model BanquetItem {
  id            String         @id @default(cuid())
  bookingId     String
  booking       BanquetBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItemId    String?
  nameSnapshot  String
  priceSnapshot Decimal        @db.Decimal(10, 2)
  quantity      Int            @default(1)

  @@index([bookingId])
  @@map("banquet_items")
}

// Post-meal rating + comment.
model Feedback {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId      String?    @unique
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  rating       Int // 1-5
  comment      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@map("feedback")
}

// ---------------------------------------------------------------------------
// Platform's own vendor bills (Razorpay, Resend, WhatsApp Cloud API, hosting,
// etc.) — NOT tenant billing. Manually entered so the operator can see what's
// coming due and never miss a renewal. See src/app/superadmin/vendor-bills.
// ---------------------------------------------------------------------------

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

model PlatformSubscription {
  id            String       @id @default(cuid())
  vendor        String // e.g. "Razorpay", "Resend", "Railway"
  description   String? // what it's for
  amount        Decimal      @db.Decimal(10, 2)
  currency      String       @default("INR")
  billingCycle  BillingCycle @default(MONTHLY)
  nextRenewalAt DateTime
  autoRenews    Boolean      @default(true)
  paymentNote   String? // e.g. "auto-debit, company card ending 4242"
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("platform_subscriptions")
}

// ---------------------------------------------------------------------------
// Messaging delivery log — every send attempt through src/lib/messaging/
// provider.ts, so failure rate per channel is visible instead of only living
// in each caller's local error handling. Global (not per-tenant) for now — see
// src/app/superadmin/health. ponytail: unbounded growth, add a retention cron
// (e.g. prune >90d) if this table ever becomes a real size concern.
// ---------------------------------------------------------------------------

enum MessageChannel {
  EMAIL
  WHATSAPP
  SMS
}

model MessageDeliveryLog {
  id        String         @id @default(cuid())
  channel   MessageChannel
  ok        Boolean
  mocked    Boolean        @default(false) // sent to console, not a real provider
  error     String?
  createdAt DateTime       @default(now())

  @@index([channel, createdAt])
  @@map("message_delivery_logs")
}

// ---------------------------------------------------------------------------
// Payment reconciliation events — persisted alongside the one-off notifyOps
// alerts in src/lib/orders/sweep.ts and src/app/api/webhook/razorpay/route.ts,
// so "how often does this happen" is visible in src/app/superadmin/health
// instead of only ever existing as a Slack/email that scrolls away.
// ---------------------------------------------------------------------------

enum ReconciliationEventType {
  LATE_WEBHOOK_RECOVERED // sweep found a captured payment the webhook missed
  UNMATCHED_PAYMENT // Razorpay confirmed a payment matching no order/plan/overage
  UNMATCHED_SUBSCRIPTION // Razorpay confirmed a subscription event matching no restaurant
}

model PaymentReconciliationEvent {
  id           String                  @id @default(cuid())
  type         ReconciliationEventType
  restaurantId String? // no relation (cross-cutting platform log — see PlatformAuditLog)
  reference    String? // razorpay order/payment/subscription id
  detail       String?
  createdAt    DateTime                @default(now())

  @@index([type, createdAt])
  @@map("payment_reconciliation_events")
}

// A raw-material supplier — closes the "Supplier Management" gap vs.
// competitors. Purchase orders reference a supplier and, once received, top
// up Ingredient.stockQty (logged as a RESTOCK IngredientLedgerEntry).
model Supplier {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime @default(now())

  purchaseOrders PurchaseOrder[]

  @@index([restaurantId])
  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  restaurantId String
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  status       PurchaseOrderStatus @default(DRAFT)
  createdByName String?
  createdAt    DateTime            @default(now())
  receivedAt   DateTime?

  lines PurchaseOrderLine[]

  @@index([restaurantId, status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qty             Decimal       @db.Decimal(10, 2)
  unitCost        Decimal       @db.Decimal(10, 2)

  @@index([purchaseOrderId])
  @@map("purchase_order_lines")
}

// A physical billing counter/register — closes the "Multi POS Setup" gap vs.
// competitors (handle volume across multiple simultaneous billing counters).
// Purely a label CashShift can attach to; multiple staff can already run
// independent concurrent shifts (one open shift per adminUserId), this just
// gives each one a named station instead of an anonymous shared drawer.
model Register {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  createdAt    DateTime   @default(now())

  cashShifts CashShift[]

  @@index([restaurantId])
  @@map("registers")
}

// A staff member's cash-register session — closes the "Cash Register/Till"
// gap vs. competitors. Cash collected during the shift is approximated as
// paid COUNTER orders updated within [openedAt, closedAt] (Order has no
// dedicated paidAt field; updatedAt is the closest proxy — see the ponytail
// note on closeCashShiftAction for the known limitation this implies).
model CashShift {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  adminUserId    String
  adminUser      AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  registerId     String?
  register       Register?  @relation(fields: [registerId], references: [id], onDelete: SetNull)
  openingFloat   Decimal    @db.Decimal(10, 2)
  openedAt       DateTime   @default(now())
  closingCounted Decimal?   @db.Decimal(10, 2)
  expectedCash   Decimal?   @db.Decimal(10, 2)
  variance       Decimal?   @db.Decimal(10, 2)
  denomination   Json? // {"500": 2, "100": 5, ...} note/coin counts at close
  closedAt       DateTime?

  @@index([restaurantId, openedAt])
  @@index([registerId])
  @@map("cash_shifts")
}

// Tenant operating expenses (rent, utilities, supplies, salaries, ...) —
// closes the "Expenses Management" gap vs. competitors. Independent of
// billing/invoicing; purely for the venue's own cost tracking.
model Expense {
  id            String     @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category      String
  amount        Decimal    @db.Decimal(10, 2)
  note          String?
  incurredAt    DateTime
  createdByName String?
  createdAt     DateTime   @default(now())

  @@index([restaurantId, incurredAt])
  @@map("expenses")
}

// ---------------------------------------------------------------------------
// Application error log — every reportError() call (src/lib/observability.ts)
// also persists here, so real error volume/trend is visible in superadmin
// health instead of only reaching Sentry (which most of this app's operators
// don't have credentials configured for) or stderr.
// ponytail: unbounded growth, same as MessageDeliveryLog — prune if it matters.
// ---------------------------------------------------------------------------

model ErrorLogEntry {
  id        String   @id @default(cuid())
  context   String // e.g. "cron.sweep", "onboarding.summaryEmail"
  message   String
  createdAt DateTime @default(now())

  @@index([context, createdAt])
  @@map("error_log_entries")
}

// ---------------------------------------------------------------------------
// Simple manual support-issue log (superadmin-only). Not a full ticketing
// system — no email/WhatsApp integration, just a place to note a tenant issue
// and mark it resolved. See src/app/superadmin/support.
// ---------------------------------------------------------------------------

enum SupportTicketStatus {
  OPEN
  RESOLVED
}

model SupportTicket {
  id           String              @id @default(cuid())
  restaurantId String? // no relation — optional, may be a general/platform issue
  subject      String
  description  String?
  status       SupportTicketStatus @default(OPEN)
  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?

  @@index([status, createdAt])
  @@map("support_tickets")
}
