# ---------------------------------------------------------------------------
# Scan-to-Order — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# PostgreSQL connection string. Used by the Prisma 7 driver adapter at runtime
# (src/lib/db.ts) and by the Prisma CLI for db push / migrate / studio.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scan_to_order?schema=public"

# --- Auth -----------------------------------------------------------------
# Secret used to sign admin session JWTs (jose, HS256). Use a long random string.
AUTH_SECRET="change-me-to-a-long-random-secret"

# --- Platform -------------------------------------------------------------
# Public base URL of the app. Used to build QR code / bill links. No trailing
# slash. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Apex domain used for tenant subdomains (<username>.<domain>) and the subdomain
# rewrite middleware (src/proxy.ts). Defaults to "scan.to" if unset.
# When the Cloudflare vars below are set, each tenant gets its own proxied CNAME
# created automatically (see src/lib/cloudflare.ts) — no wildcard DNS record
# needed. On Railway, add "*.scan2order.co.in" as a custom domain once for
# routing (Cloudflare's Universal SSL terminates TLS for the proxied subdomains).
# Once set, QR codes use https://<username>.scan2order.co.in/<table> automatically.
NEXT_PUBLIC_PLATFORM_DOMAIN="scan2order.co.in"

# --- Cloudflare DNS automation (optional) ---------------------------------
# When all three are set, the app creates/updates/deletes a per-tenant CNAME in
# your Cloudflare zone as restaurants pick or change their username — replacing
# the old "*" wildcard record. Leave blank to manage DNS manually.
#   CLOUDFLARE_API_TOKEN  → a scoped API token with Zone.DNS:Edit on the zone
#                           (My Profile → API Tokens → Create Token).
#   CLOUDFLARE_ZONE_ID    → the zone's ID (dashboard → your domain → Overview,
#                           right sidebar).
#   CLOUDFLARE_DNS_TARGET → what each subdomain CNAME points at: the CNAME target
#                           Railway shows after you add "*.scan2order.co.in" as a
#                           custom domain (e.g. "xxxxxxxx.up.railway.app").
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_DNS_TARGET=""
# Records are proxied (orange cloud) by default. Set "false" for DNS-only / grey
# cloud if Railway terminates TLS with its own wildcard cert instead.
CLOUDFLARE_PROXIED="true"

# --- Platform super-admin (optional) --------------------------------------
# If both are set, `npm run db:seed` upserts a platform super-admin (no
# restaurant of its own -> lands on /superadmin). Leave unset to skip; create
# one out-of-band instead so the password never lives in the repo:
#   npm run db:superadmin -- <email> <password>
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""

# --- Payments / Razorpay (online card/UPI) --------------------------------
# Platform-level fallback keys. Restaurants may override with their own keys in
# Settings -> Payment & messaging. Leave blank to run the dev mock-payment path.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Exposed to the browser checkout. Same value as RAZORPAY_KEY_ID.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
# Razorpay webhook signing secret. Set this AND configure a webhook in the
# Razorpay dashboard (URL: <app>/api/webhook/razorpay, events: payment.captured,
# order.paid) so payments are confirmed server-side even if the diner closes the
# tab before the browser callback runs. Without it the webhook returns 503.
RAZORPAY_WEBHOOK_SECRET=""
# Auto-renew (eMandate): create a Subscription Plan per tier in the Razorpay
# dashboard and put the plan IDs here. Leave blank to keep pay-to-extend only.
# Also enable the subscription.* webhook events for the same webhook URL.
RAZORPAY_PLAN_STARTER=""
RAZORPAY_PLAN_PRO=""

# --- Error reporting (optional) -------------------------------------------
# Sentry DSN. When set, server errors are forwarded to Sentry (no SDK needed);
# leave blank to just log to stderr.
SENTRY_DSN=""

# --- Scheduled jobs -------------------------------------------------------
# Shared secret guarding /api/cron/sweep (stale-order cleanup). Point a Railway
# cron (or any scheduler) at that URL every ~15 min with header
# "Authorization: Bearer <CRON_SECRET>". Without it the endpoint returns 503.
CRON_SECRET=""

# --- Messaging (WhatsApp OTP + bill) --------------------------------------
# Provider: "console" (log locally, default), "twilio", or "meta" (WhatsApp
# Cloud API — free, no Twilio). Email (Resend, above) works regardless.
MESSAGING_PROVIDER="console"

# -- Meta WhatsApp Cloud API (MESSAGING_PROVIDER="meta") --
# From the Meta dashboard: a permanent access token + the sender's phone-number
# ID. Business-initiated messages need PRE-APPROVED templates, so create two
# (category Utility is simplest — Authentication also works for OTP) and set
# their names below:
#   OTP template  → 1 body variable:  "Your code is {{1}}. Expires in 5 min."
#   Bill template → 3 body variables: "Bill from {{1}} — total {{2}}. View: {{3}}"
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_ID=""
META_WHATSAPP_API_VERSION="v21.0"
META_WHATSAPP_LANG="en"
META_WHATSAPP_OTP_TEMPLATE=""
META_WHATSAPP_BILL_TEMPLATE=""

# -- Twilio (MESSAGING_PROVIDER="twilio") --
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Twilio WhatsApp sender, e.g. "whatsapp:+14155238886".
TWILIO_WHATSAPP_FROM=""
# Twilio SMS sender (optional).
TWILIO_SMS_FROM=""

# --- Email / Resend -------------------------------------------------------
# Transactional email (bill delivery). Get a key at resend.com and verify your
# sending domain. Leave blank to log emails to the console (dev).
RESEND_API_KEY=""
# Sender address at your verified domain (name optional).
EMAIL_FROM="Scan to Order <noreply@email.astechlabs.co.in>"

# --- Web Push (VAPID) -----------------------------------------------------
# Generate once with: npx web-push generate-vapid-keys
# Push only fires when these are set and the browser is in a secure context.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
# Public VAPID key exposed to the browser to create push subscriptions.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Redis (optional) -----------------------------------------------------
# When set, the realtime bus (SSE live updates) and the order rate limiter use
# Redis pub/sub + counters, so they stay correct across multiple instances /
# serverless. Leave unset for single-instance dev (falls back to in-memory).
REDIS_URL=""
